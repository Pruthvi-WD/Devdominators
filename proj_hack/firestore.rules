rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: profiles
    // Document ID: {uid}
    // Fields: uid, name, subjects, studyHoursPerDay, learningStyle, examDate, targetScore, createdAt
    //
    // Collection: studySessions
    // Document ID: {sessionId}
    // Fields: uid, subject, topic, durationMinutes, timestamp, engagementLevel
    //
    // Collection: quizScores
    // Document ID: {scoreId}
    // Fields: uid, subject, topic, score, total, timestamp
    //
    // Collection: revisionTasks
    // Document ID: {taskId}
    // Fields: uid, subject, topic, dueDate, priority, status, source
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.uid;
    }

    function isRequestOwner() {
      return isAuthenticated() && request.auth.uid == request.resource.data.uid;
    }

    function isValidProfile(data) {
      return data.keys().hasAll(['uid', 'name']) &&
             data.uid is string &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100;
    }

    function isValidStudySession(data) {
      return data.keys().hasAll(['uid', 'subject', 'topic', 'durationMinutes', 'timestamp']) &&
             data.uid is string &&
             data.subject is string &&
             data.topic is string &&
             data.durationMinutes is number &&
             data.timestamp is string;
    }

    function isValidQuizScore(data) {
      return data.keys().hasAll(['uid', 'subject', 'topic', 'score', 'total', 'timestamp']) &&
             data.uid is string &&
             data.subject is string &&
             data.topic is string &&
             data.score is number &&
             data.total is number &&
             data.timestamp is string;
    }

    function isValidRevisionTask(data) {
      return data.keys().hasAll(['uid', 'subject', 'topic', 'dueDate', 'status']) &&
             data.uid is string &&
             data.subject is string &&
             data.topic is string &&
             data.dueDate is string &&
             data.status in ['Pending', 'Completed'];
    }

    function isValidStudyPlanTask(data) {
      return data.keys().hasAll(['uid', 'day', 'timeSlot', 'subject', 'topic', 'status', 'type']) &&
             data.uid is string &&
             data.day is string &&
             data.timeSlot is string &&
             data.subject is string &&
             data.topic is string &&
             data.status in ['Pending', 'Completed'] &&
             data.type in ['Study', 'Quiz', 'Revision'];
    }

    // Rules
    match /profiles/{uid} {
      allow read: if isOwner(uid);
      allow create: if isOwner(uid) && isValidProfile(request.resource.data);
      allow update: if isOwner(uid) && isValidProfile(request.resource.data);
      allow delete: if isOwner(uid);
    }

    match /studySessions/{sessionId} {
      allow read: if isDocOwner();
      allow create: if isRequestOwner() && isValidStudySession(request.resource.data);
      allow update: if isDocOwner() && isRequestOwner() && isValidStudySession(request.resource.data);
      allow delete: if isDocOwner();
    }

    match /quizScores/{scoreId} {
      allow read: if isDocOwner();
      allow create: if isRequestOwner() && isValidQuizScore(request.resource.data);
      allow update: if isDocOwner() && isRequestOwner() && isValidQuizScore(request.resource.data);
      allow delete: if isDocOwner();
    }

    match /revisionTasks/{taskId} {
      allow read: if isDocOwner();
      allow create: if isRequestOwner() && isValidRevisionTask(request.resource.data);
      allow update: if isDocOwner() && isRequestOwner() && isValidRevisionTask(request.resource.data);
      allow delete: if isDocOwner();
    }

    match /studyPlanTasks/{taskId} {
      allow read: if isDocOwner();
      allow create: if isRequestOwner() && isValidStudyPlanTask(request.resource.data);
      allow update: if isDocOwner() && isRequestOwner() && isValidStudyPlanTask(request.resource.data);
      allow delete: if isDocOwner();
    }
  }
}
