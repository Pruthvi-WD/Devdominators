{
  "entities": {
    "StudentProfile": {
      "title": "Student Profile",
      "description": "The core digital twin profile of a student.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "User ID from Firebase Auth" },
        "name": { "type": "string" },
        "subjects": { "type": "array", "items": { "type": "string" } },
        "studyHoursPerDay": { "type": "number" },
        "learningStyle": { "type": "string", "enum": ["Visual", "Auditory", "Reading-Writing", "Kinesthetic"] },
        "examDate": { "type": "string", "format": "date-time" },
        "targetScore": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "name"]
    },
    "StudySession": {
      "title": "Study Session",
      "description": "A record of a student's study activity.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "subject": { "type": "string" },
        "topic": { "type": "string" },
        "durationMinutes": { "type": "number" },
        "timestamp": { "type": "string", "format": "date-time" },
        "engagementLevel": { "type": "number", "description": "1-10 scale" }
      },
      "required": ["uid", "subject", "topic", "durationMinutes", "timestamp"]
    },
    "QuizScore": {
      "title": "Quiz Score",
      "description": "Results from a quiz or test.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "subject": { "type": "string" },
        "topic": { "type": "string" },
        "score": { "type": "number" },
        "total": { "type": "number" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "subject", "topic", "score", "total", "timestamp"]
    },
    "RevisionTask": {
      "title": "Revision Task",
      "description": "A scheduled revision task generated by the AI.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "subject": { "type": "string" },
        "topic": { "type": "string" },
        "dueDate": { "type": "string", "format": "date-time" },
        "priority": { "type": "string", "enum": ["High", "Medium", "Low"] },
        "status": { "type": "string", "enum": ["Pending", "Completed"] },
        "source": { "type": "string", "description": "AI_GENERATED or MANUAL" }
      },
      "required": ["uid", "subject", "topic", "dueDate", "status"]
    },
    "StudyPlanTask": {
      "title": "Study Plan Task",
      "description": "A specific task in the AI-generated study plan.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "day": { "type": "string", "format": "date" },
        "timeSlot": { "type": "string" },
        "subject": { "type": "string" },
        "topic": { "type": "string" },
        "objective": { "type": "string" },
        "status": { "type": "string", "enum": ["Pending", "Completed"] },
        "type": { "type": "string", "enum": ["Study", "Quiz", "Revision"] }
      },
      "required": ["uid", "day", "timeSlot", "subject", "topic", "status", "type"]
    }
  },
  "firestore": {
    "/profiles/{uid}": {
      "schema": "StudentProfile",
      "description": "User profiles indexed by UID"
    },
    "/studySessions/{sessionId}": {
      "schema": "StudySession",
      "description": "Collection of all study sessions"
    },
    "/quizScores/{scoreId}": {
      "schema": "QuizScore",
      "description": "Collection of all quiz scores"
    },
    "/revisionTasks/{taskId}": {
      "schema": "RevisionTask",
      "description": "Collection of all revision tasks"
    },
    "/studyPlanTasks/{taskId}": {
      "schema": "StudyPlanTask",
      "description": "Collection of all study plan tasks"
    }
  }
}
